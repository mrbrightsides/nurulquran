{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "SavedResult": {
      "title": "Saved Identification Result",
      "description": "A Quranic verse or Hadith saved by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "reference": { "type": "string" },
        "arabicText": { "type": "string" },
        "translation": { "type": "string" },
        "translationID": { "type": "string" },
        "type": { "type": "string", "enum": ["Quran", "Hadith", "Unknown"] },
        "confidence": { "type": "number" },
        "timestamp": { "type": "number" },
        "userCategory": { "type": "string" },
        "userNote": { "type": "string" }
      },
      "required": ["userId", "title", "reference", "arabicText", "timestamp"]
    },
    "Circle": {
      "title": "Study Circle",
      "description": "A collaborative study group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" },
        "activeVerse": { "type": "object" }
      },
      "required": ["id", "name", "createdBy", "createdAt"]
    },
    "Message": {
      "title": "Circle Message",
      "description": "A message or shared verse in a study circle",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "circleId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "number" },
        "type": { "type": "string", "enum": ["text", "verse"] },
        "verseData": { "type": "object" }
      },
      "required": ["circleId", "userId", "timestamp", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/saved_results/{resultId}": {
      "schema": "SavedResult",
      "description": "Collection of saved verses and hadiths"
    },
    "/circles/{circleId}": {
      "schema": "Circle",
      "description": "Study circle metadata"
    },
    "/circles/{circleId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a study circle"
    }
  }
}
